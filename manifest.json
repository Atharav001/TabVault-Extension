{
  "manifest_version": 3,
  "name": "MemoryVault",
  "version": "0.0.1",
  "description": "A Brave sidepanel extension to save, organize, and revisit your browsing tabs.",
  "permissions": [
    "sidePanel",
    "tabs",
    "tabGroups",
    "alarms",
    "contextMenus",
    "scripting",
    "storage",
    "downloads"
  ],
  "icons": {
    "16": "public/icon.png",
    "48": "public/icon.png",
    "128": "public/icon.png"
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MemoryVault",
    "default_icon": {
      "16": "public/icon.png",
      "48": "public/icon.png",
      "128": "public/icon.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "commands": {
    "open-side-panel": {
      "description": "Open MemoryVault side panel",
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      }
    }
  }
}
